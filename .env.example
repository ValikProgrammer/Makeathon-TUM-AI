# HappyRobot
HAPPYROBOT_API_KEY=your_happyrobot_api_key_here
HAPPYROBOT_CALLER_WEBHOOK_URL=https://app.happyrobot.ai/api/v1/workflows/YOUR_CALLER_WORKFLOW_ID/trigger
HAPPYROBOT_SCOUT_WEBHOOK_URL=https://app.happyrobot.ai/api/v1/workflows/YOUR_SCOUT_WORKFLOW_ID/trigger
HAPPYROBOT_CLOSER_WEBHOOK_URL=https://app.happyrobot.ai/api/v1/workflows/YOUR_CLOSER_WORKFLOW_ID/trigger

# Our app public URL (HappyRobot needs this to POST back events)
# Use ngrok or Vercel preview URL during hackathon
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
WEBHOOK_SECRET=change_this_to_random_string
